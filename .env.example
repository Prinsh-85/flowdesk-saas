# ── Frontend Environment Variables ─────────────────────────────────────────────
# Copy this file to .env for local development
# For production: set these in Vercel → Project Settings → Environment Variables

# The full URL of your backend API (no trailing slash)
# Local dev:
VITE_API_URL=http://localhost:8080/api
# Production (uncomment when deploying):
# VITE_API_URL=https://flowdesk-backend.onrender.com/api

# WebSocket URL for local dev vs production
# VITE_WS_URL=http://localhost:8080/ws
# VITE_WS_URL=https://flowdesk-backend.onrender.com/ws
